# Monorepo root — shared defaults (copy sections into apps/api/.env as needed)

# API
PORT=3001
DATABASE_URL=postgresql://mopd_cms:replace-with-password@localhost:5433/mopd_cms
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
APP_PUBLIC_URL=http://localhost:3000

# Email (dev: console or smtp+Mailpit — see CMS SRS + SDS/MoPD_CMS_Prod_Environment_Notes.md)
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@localhost
SMTP_HOST=localhost
SMTP_PORT=1025

# MinIO (documents FR-09) — buckets created on API startup when using minio driver
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_QUARANTINE=mopd-quarantine
MINIO_BUCKET_LIVE=mopd-live
MINIO_BUCKET_EXPORTS=mopd-exports
MINIO_PRESIGN_TTL_SEC=900
REPORT_EXPORT_MAX_ROWS=50000
REPORT_EXPORT_TTL_SEC=86400
DOCUMENT_STORAGE_DRIVER=minio
DOCUMENT_MAX_BYTES=26214400
DOCUMENT_ALLOWED_MIME=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/msword,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel,image/jpeg,image/png,image/gif,video/mp4,audio/mpeg

# ClamAV (documents FR-09)
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
VIRUS_SCANNER=clamav
