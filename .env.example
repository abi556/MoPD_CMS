# API
PORT=3001
DATABASE_URL=postgresql://cms:password@localhost:5432/cms
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me

# Web (`apps/web`) — REST prefix for browser fetches (`resolveApiV1Prefix` prefers URL over BASE_URL)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
# Public origin mailed in reset links (`apps/api`); must match clickable URL for CORS/CSRF
APP_PUBLIC_URL=http://localhost:3000

# Email (dev: console or smtp+Mailpit — see CMS SRS + SDS/MoPD_CMS_Prod_Environment_Notes.md)
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@localhost
SMTP_HOST=localhost
SMTP_PORT=1025

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
