# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
# Ensure this matches the credentials in infra/docker/docker-compose.yml
DATABASE_URL="postgresql://cms:password@localhost:5432/cms"

# Redis (for caching and queues)
REDIS_URL="redis://localhost:6379"

# Authentication Secrets
# WARNING: Change these in production!
JWT_ACCESS_SECRET="dev-jwt-access-secret-change-me"
JWT_REFRESH_SECRET="dev-jwt-refresh-secret-change-me"

# Auth seed users (used by startup seeding and `pnpm --filter @mopd-cms/api run seed:auth`)
AUTH_SEED_ENABLED=false
AUTH_SEED_SUPER_ADMIN_ROLE_ID="role-super-admin"
AUTH_SEED_CASE_OFFICER_ROLE_ID="role-case-officer"
AUTH_SEED_SUPER_ADMIN_ID="replace-with-admin-user-id"
AUTH_SEED_SUPER_ADMIN_EMAIL="replace-with-admin-email@example.com"
AUTH_SEED_SUPER_ADMIN_PASSWORD="replace-with-strong-admin-password"
AUTH_SEED_CASE_OFFICER_ID="replace-with-officer-user-id"
AUTH_SEED_CASE_OFFICER_EMAIL="replace-with-officer-email@example.com"
AUTH_SEED_CASE_OFFICER_PASSWORD="replace-with-strong-officer-password"
