# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
# Ensure this matches the credentials in infra/docker/docker-compose.yml
DATABASE_URL="postgresql://cms:password@localhost:5432/cms"

# Redis (for caching and queues)
REDIS_URL="redis://localhost:6379"

# Authentication Secrets
# WARNING: Change these in production!
JWT_ACCESS_SECRET="dev-jwt-access-secret-change-me"
JWT_REFRESH_SECRET="dev-jwt-refresh-secret-change-me"
