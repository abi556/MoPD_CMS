# Server
PORT=3001
NODE_ENV=development
TRUST_PROXY=false
CORS_ALLOWED_ORIGINS="http://localhost:3000"

# Database (PostgreSQL)
# Ensure this matches the credentials in infra/docker/docker-compose.yml
# Match infra/docker + root .env.docker (default host port 5433)
DATABASE_URL="postgresql://mopd_cms:replace-with-password@localhost:5433/mopd_cms"

# Redis (for caching and queues)
# Use `redis://` for plain TCP, or `rediss://` for TLS (e.g. Azure Cache for Redis,
# AWS ElastiCache with in-transit encryption). BullMQ + ioredis pick TLS automatically
# from the URL scheme.
REDIS_URL="redis://localhost:6379"
# Max reconnect attempts before BullMQ gives up (each attempt up to 5s apart)
REDIS_MAX_RETRIES=20

# Authentication Secrets
# WARNING: Change these in production!
JWT_ACCESS_SECRET="dev-jwt-access-secret-change-me"
JWT_REFRESH_SECRET="dev-jwt-refresh-secret-change-me"
AUTH_REFRESH_COOKIE_NAME="refresh_token"
AUTH_REFRESH_TTL_MS=604800000
AUTH_COOKIE_SECURE=false
AUTH_CSRF_ENFORCED=false
AUTH_CSRF_TRUSTED_ORIGINS="http://localhost:3000"
AUTH_BCRYPT_COST=12

# Account lockout (per email; aligns with SDS-style defaults)
AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_DURATION_MS=900000
AUTH_LOCKOUT_ATTEMPT_WINDOW_MS=900000

# Password reset token (Redis; email via notifications module)
AUTH_PASSWORD_RESET_TOKEN_TTL_MS=3600000
# Dev only: log reset tokens to server console (never true in production)
AUTH_PASSWORD_RESET_LOG_TOKEN=false

# Staff password policy (change-password, reset-password, admin create-user)
# Enforced in code — no env vars. Rules: min 12 chars, upper, lower, digit, special.
# bcrypt cost is controlled by AUTH_BCRYPT_COST above.

# Notifications / email (see CMS SRS + SDS/MoPD_CMS_Prod_Environment_Notes.md)
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@localhost
APP_PUBLIC_URL=http://localhost:3000
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_API_KEY=

# Complaint emails: tracking link base (optional). If unset, uses {APP_PUBLIC_URL}/track/{referenceNo}.
# Until the public web portal exists, you can point at the API track endpoint, e.g.:
# APP_PUBLIC_TRACK_URL_PREFIX=http://localhost:3001/api/v1/complaints/track
APP_PUBLIC_TRACK_URL_PREFIX=

# Local dev: set to true to disable API rate limiting (avoids false 429 while testing forms).
# DISABLE_THROTTLE=true

# Comma-separated statuses for which complainants receive `complaint_transition` email.
# Default: high-signal milestones only.
NOTIFY_TRANSITION_STATUSES=CLOSED,RESPONSE_ISSUED,AWAITING_FEEDBACK

# Object storage (MinIO / S3-compatible) — documents module FR-09
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_QUARANTINE=mopd-quarantine
MINIO_BUCKET_LIVE=mopd-live
MINIO_BUCKET_EXPORTS=mopd-exports
MINIO_PRESIGN_TTL_SEC=900
REPORT_EXPORT_MAX_ROWS=50000
REPORT_EXPORT_TTL_SEC=86400
DOCUMENT_STORAGE_DRIVER=minio
DOCUMENT_MAX_BYTES=26214400
DOCUMENT_ALLOWED_MIME=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/msword,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel,image/jpeg,image/png,image/gif,video/mp4,audio/mpeg

# Virus scanning (ClamAV clamd TCP)
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
VIRUS_SCANNER=clamav

# MFA (TOTP + optional email OTP) — endpoints: POST /auth/mfa/enroll, /mfa/confirm, /mfa/verify
#
# AUTH_MFA_REQUIRED controls org policy (not whether MFA code runs):
#   false (dev default) — MFA optional for most staff; users who enrolled still get login challenge
#   true  (production)  — policy "required"; non-admin roles cannot disable MFA
# Login MFA challenge is driven by user.mfaEnabled in the database (after enroll + confirm).
AUTH_MFA_REQUIRED=false
#
# Encrypts TOTP secrets at rest (AES-256-GCM). Copy .env.example → .env, then generate YOUR key:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Leave empty only for quick local smoke tests (dev fallback key — not for real use).
# MUST be set in production; store in a secret manager, never commit .env.
TOTP_ENCRYPTION_KEY=
#
# TOTP clock skew tolerance: 1 = accept codes from ±1 time step (±30 seconds). Safe default: 1.
MFA_TOTP_WINDOW=1
# Email OTP lifetime in ms. 300000 = 5 minutes. Requires working EMAIL_PROVIDER / SMTP.
MFA_EMAIL_OTP_TTL_MS=300000

# SLA monitor (BullMQ repeatable job)
SLA_MONITOR_INTERVAL_MS=300000
SLA_BUSINESS_HOURS_ONLY=false

# Bull Board (BullMQ admin UI at /admin/queues)
# In production: keep BULL_BOARD_ENABLED=false unless you actively need it,
# and additionally restrict the path via reverse proxy or VPN.
# Username/password are HTTP Basic Auth credentials. Use a strong password.
BULL_BOARD_ENABLED=false
BULL_BOARD_USERNAME="replace-me"
BULL_BOARD_PASSWORD="replace-with-strong-password"

# Auth seed users (used by startup seeding and `pnpm --filter @mopd-cms/api run seed:auth`)
# NOTE: SDS §6.2 / §7.1 specify UUID v4 IDs for users. Use UUID v4 strings for *_ID values.
# Role IDs intentionally stay as human-readable codes (reference data, not user-generated).
AUTH_SEED_ENABLED=false
AUTH_SEED_SUPER_ADMIN_ROLE_ID="role-super-admin"
AUTH_SEED_CASE_OFFICER_ROLE_ID="role-case-officer"
AUTH_SEED_SUPER_ADMIN_ID="00000000-0000-4000-8000-000000000001"
AUTH_SEED_SUPER_ADMIN_EMAIL="replace-with-admin-email@example.com"
AUTH_SEED_SUPER_ADMIN_PASSWORD="replace-with-strong-admin-password"
AUTH_SEED_CASE_OFFICER_ID="00000000-0000-4000-8000-000000000002"
AUTH_SEED_CASE_OFFICER_EMAIL="replace-with-officer-email@example.com"
AUTH_SEED_CASE_OFFICER_PASSWORD="replace-with-strong-officer-password"
# Optional dev role users (defaults in test/e2e/helpers/auth-seed.ts when AUTH_SEED_ENABLED=true):
# AUTH_SEED_SYSTEM_ADMIN_EMAIL, AUTH_SEED_COMPLAINTS_ADMIN_EMAIL, AUTH_SEED_REVIEWER_EMAIL,
# AUTH_SEED_COMMUNICATIONS_EMAIL, AUTH_SEED_AUDITOR_EMAIL, AUTH_SEED_OMBUDSPERSON_EMAIL,
# AUTH_SEED_OBSERVER_EMAIL, AUTH_SEED_CASE_OFFICER_2_EMAIL — see docs/RBAC.md

# -------------------------------------------------------------------
# Production recommendations (copy values into your production env)
# -------------------------------------------------------------------
# NODE_ENV=production
# TRUST_PROXY=true
# CORS_ALLOWED_ORIGINS="https://cms.mopd.gov.et"
#
# JWT_ACCESS_SECRET="replace-with-64+char-random-secret"
# JWT_REFRESH_SECRET="replace-with-64+char-random-secret"
# AUTH_COOKIE_SECURE=true
# AUTH_CSRF_ENFORCED=true
# AUTH_CSRF_TRUSTED_ORIGINS="https://cms.mopd.gov.et"
# AUTH_BCRYPT_COST=12
#
# AUTH_SEED_ENABLED=false
#
# MFA (production — TOTP_ENCRYPTION_KEY is REQUIRED)
# TOTP_ENCRYPTION_KEY="replace-with-base64-encoded-32-byte-key"
# AUTH_MFA_REQUIRED=true
# MFA_TOTP_WINDOW=1
# MFA_EMAIL_OTP_TTL_MS=300000
#
# Documents / MinIO / ClamAV (production — use managed S3-compatible storage + AV)
# MINIO_ENDPOINT=s3.mopd.gov.et
# MINIO_PORT=443
# MINIO_USE_SSL=true
# MINIO_ACCESS_KEY=replace-me
# MINIO_SECRET_KEY=replace-me
# MINIO_BUCKET_QUARANTINE=mopd-quarantine-prod
# MINIO_BUCKET_LIVE=mopd-live-prod
# MINIO_PRESIGN_TTL_SEC=900
# DOCUMENT_STORAGE_DRIVER=minio
# DOCUMENT_MAX_BYTES=26214400
# CLAMAV_HOST=clamav.internal
# CLAMAV_PORT=3310
# VIRUS_SCANNER=clamav
