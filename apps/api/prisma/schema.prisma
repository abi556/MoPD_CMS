generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ComplaintStatus {
  SUBMITTED
  TRIAGE
  ASSIGNED
  IN_INVESTIGATION
  DRAFT_RESPONSE
  QA_LEGAL_REVIEW
  RESPONSE_ISSUED
  AWAITING_FEEDBACK
  APPEAL
  CLOSED
}

enum ComplaintChannel {
  WEB
  ASSISTED
  EMAIL
  SMS
  USSD
}

enum ComplaintLocale {
  en
  am
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SlaStatus {
  ACTIVE
  PAUSED
  COMPLETED
  BREACHED
}

enum CaseNoteVisibility {
  INTERNAL
  RESTRICTED
}

enum CaseTaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum ReferenceRecoveryInquiryStatus {
  PENDING
  IN_REVIEW
  RESOLVED
  REJECTED
}

enum DocumentScanStatus {
  PENDING
  SCANNING
  CLEAN
  INFECTED
  FAILED
}

model ComplaintCategory {
  id         String              @id @default(uuid())
  code       String              @unique
  nameEn     String
  nameAm     String?
  parentId   String?
  isActive   Boolean             @default(true)
  sortOrder  Int                 @default(0)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  parent     ComplaintCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children   ComplaintCategory[] @relation("CategoryHierarchy")
  complaints Complaint[]
  slaConfigs SlaConfig[]

  @@index([parentId])
  @@index([isActive, sortOrder])
}

model OrgUnit {
  id        String      @id @default(uuid())
  code      String      @unique
  nameEn    String
  nameAm    String?
  parentId  String?
  isActive  Boolean     @default(true)
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  parent    OrgUnit?    @relation("OrgUnitHierarchy", fields: [parentId], references: [id])
  children  OrgUnit[]   @relation("OrgUnitHierarchy")
  complaints Complaint[]

  @@index([parentId])
  @@index([isActive, sortOrder])
}

model Complaint {
  id              String              @id @default(uuid())
  sequenceNo      Int                 @unique @default(autoincrement())
  referenceNo     String              @unique
  status          ComplaintStatus     @default(SUBMITTED)
  priority        Priority            @default(NORMAL)
  categoryId      String?
  orgUnitId       String?
  channel         ComplaintChannel
  subject         String
  description     String
  submittedAt     DateTime            @default(now())
  locale          ComplaintLocale
  consentGiven    Boolean
  complainantName String?
  complainantEmail String?
  complainantPhone String?
  assignedToUserId String?
  assignedByUserId String?
  assignedAt      DateTime?
  assignmentReason String?
  lastTransitionByUserId String?
  lastTransitionAt DateTime?
  lastTransitionReason String?
  responseDraft   String?
  history         ComplaintHistory[]
  notes           CaseNote[]
  tasks           CaseTask[]
  documents       Document[]
  sla             ComplaintSla?
  category        ComplaintCategory?  @relation(fields: [categoryId], references: [id])
  orgUnit         OrgUnit?            @relation(fields: [orgUnitId], references: [id])
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([referenceNo])
  @@index([submittedAt])
  @@index([categoryId])
  @@index([orgUnitId])
  @@index([complainantEmail])
  @@index([complainantPhone])
}

model ReferenceRecoveryInquiry {
  id                       String                         @id @default(uuid())
  status                   ReferenceRecoveryInquiryStatus @default(PENDING)
  locale                   ComplaintLocale
  subjectFragment          String
  submittedDateGregorian   DateTime?
  submittedDateEthiopian   String?
  categoryId               String?
  orgUnitId                String?
  contactEmail             String
  additionalNotes          String?
  matchedComplaintId       String?
  resolvedReferenceNo      String?
  assignedToUserId         String?
  createdAt                DateTime                       @default(now())
  updatedAt                DateTime                       @updatedAt

  @@index([status, createdAt])
  @@index([categoryId])
  @@index([orgUnitId])
}

model ComplaintHistory {
  id            String          @id @default(uuid())
  complaintId   String
  action        String
  fromStatus    ComplaintStatus?
  toStatus      ComplaintStatus
  actorUserId   String
  reason        String?
  createdAt     DateTime        @default(now())
  complaint     Complaint       @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId, createdAt])
}

model CaseNote {
  id          String             @id @default(uuid())
  complaintId String
  authorId    String
  body        String
  visibility  CaseNoteVisibility @default(INTERNAL)
  createdAt   DateTime           @default(now())
  complaint   Complaint          @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId, createdAt])
}

model CaseTask {
  id          String         @id @default(uuid())
  complaintId String
  assigneeId  String
  createdById String
  title       String
  status      CaseTaskStatus @default(OPEN)
  dueAt       DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  complaint   Complaint      @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId, status])
  @@index([complaintId, dueAt])
}

model User {
  id                 String     @id @default(uuid())
  email              String     @unique
  passwordHash       String
  passwordVersion    Int        @default(0)
  mustChangePassword Boolean    @default(false)
  mustEnrollMfa      Boolean    @default(false)
  mfaEnabled         Boolean    @default(false)
  mfaMethod          String?
  totpSecret         String?
  totpVerifiedAt     DateTime?
  isActive           Boolean    @default(true)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  userRoles          UserRole[]
  documents          Document[]
}

model Document {
  id            String             @id @default(uuid())
  complaintId   String
  ownerUserId   String
  originalName  String
  mimeType      String
  sizeBytes     Int
  scanStatus    DocumentScanStatus @default(PENDING)
  storageKey    String
  quarantineKey String?
  liveKey       String?
  scanError     String?
  scannedAt     DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  complaint     Complaint          @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  owner         User               @relation(fields: [ownerUserId], references: [id])

  @@index([complaintId, createdAt])
  @@index([scanStatus])
}

model Role {
  id              String           @id
  name            String           @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  userRoles       UserRole[]
  rolePermissions RolePermission[]
}

model Permission {
  id              String           @id
  code            String           @unique
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
}

model RolePermission {
  roleId        String
  permissionId  String
  createdAt     DateTime   @default(now())
  role          Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model UserRole {
  userId     String
  roleId     String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model AuditLog {
  id            String   @id @default(uuid())
  eventType     String
  actorUserId   String?
  actorRole     String?
  entityType    String?
  entityId      String?
  correlationId String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([eventType, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId, createdAt])
}

// Uniqueness across (priority, categoryId) is enforced via PARTIAL UNIQUE INDEXES
// created in migration `20260512150000_sla_config_partial_unique`. We can't use
// `@@unique([priority, categoryId])` here because Postgres treats NULL as
// distinct in unique indexes by default, which would allow two generic configs
// (categoryId IS NULL) with the same priority — see PROJ_LEARNING_NOTES §28.
model SlaConfig {
  id                   String             @id @default(uuid())
  name                 String
  priority             Priority
  categoryId           String?
  targetHours          Int
  warningThresholdPct  Int                @default(80)
  escalationRoleId     String?
  isActive             Boolean            @default(true)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  trackers             ComplaintSla[]
  category             ComplaintCategory? @relation(fields: [categoryId], references: [id])

  @@index([priority, isActive])
}

model ComplaintSla {
  id            String    @id @default(uuid())
  complaintId   String    @unique
  slaConfigId   String
  startedAt     DateTime  @default(now())
  targetAt      DateTime
  warningAt     DateTime
  warnedAt      DateTime?
  breachedAt    DateTime?
  completedAt   DateTime?
  status        SlaStatus @default(ACTIVE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  complaint     Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  slaConfig     SlaConfig @relation(fields: [slaConfigId], references: [id])

  @@index([status])
  @@index([targetAt])
}

enum NotificationChannel {
  email
  sms
}

enum NotificationDeliveryStatus {
  queued
  sent
  failed
}

model NotificationTemplate {
  id        String              @id @default(uuid())
  key       String
  locale    ComplaintLocale
  channel   NotificationChannel
  subject   String
  bodyHtml  String
  bodyText  String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([key, locale, channel])
}

model NotificationDelivery {
  id             String                     @id @default(uuid())
  templateKey    String
  to             String
  channel        NotificationChannel
  status         NotificationDeliveryStatus @default(queued)
  retries        Int                        @default(0)
  lastError      String?
  sentAt         DateTime?
  correlationId  String?
  payload        Json?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  @@index([status, createdAt])
  @@index([to, createdAt])
  @@index([correlationId])
}

enum ReportExportFormat {
  csv
  xlsx
}

enum ReportExportStatus {
  PENDING
  PROCESSING
  READY
  FAILED
  EXPIRED
}

model ReportExport {
  id            String             @id @default(uuid())
  requestedById String
  format        ReportExportFormat
  status        ReportExportStatus @default(PENDING)
  filters       Json
  storageKey    String?
  mimeType      String?
  rowCount      Int?
  errorMessage  String?
  expiresAt     DateTime?
  createdAt     DateTime           @default(now())
  completedAt   DateTime?

  @@index([requestedById, createdAt])
  @@index([status])
}
