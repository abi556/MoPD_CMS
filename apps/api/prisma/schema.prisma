generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ComplaintStatus {
  SUBMITTED
  TRIAGE
  ASSIGNED
  IN_INVESTIGATION
  DRAFT_RESPONSE
  QA_LEGAL_REVIEW
  RESPONSE_ISSUED
  AWAITING_FEEDBACK
  APPEAL
  CLOSED
}

enum ComplaintChannel {
  WEB
  ASSISTED
  EMAIL
  SMS
  USSD
}

enum ComplaintLocale {
  en
  am
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SlaStatus {
  ACTIVE
  PAUSED
  COMPLETED
  BREACHED
}

model Complaint {
  id              String          @id @default(uuid())
  sequenceNo      Int             @unique @default(autoincrement())
  referenceNo     String          @unique
  status          ComplaintStatus @default(SUBMITTED)
  priority        Priority        @default(NORMAL)
  categoryId      String?
  channel         ComplaintChannel
  subject         String
  description     String
  submittedAt     DateTime        @default(now())
  locale          ComplaintLocale
  consentGiven    Boolean
  complainantName String?
  complainantEmail String?
  complainantPhone String?
  assignedToUserId String?
  assignedByUserId String?
  assignedAt      DateTime?
  assignmentReason String?
  lastTransitionByUserId String?
  lastTransitionAt DateTime?
  lastTransitionReason String?
  history         ComplaintHistory[]
  sla             ComplaintSla?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([referenceNo])
  @@index([submittedAt])
}

model ComplaintHistory {
  id            String          @id @default(uuid())
  complaintId   String
  action        String
  fromStatus    ComplaintStatus?
  toStatus      ComplaintStatus
  actorUserId   String
  reason        String?
  createdAt     DateTime        @default(now())
  complaint     Complaint       @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId, createdAt])
}

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  passwordHash    String
  passwordVersion Int        @default(0)
  mfaEnabled      Boolean    @default(false)
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  userRoles       UserRole[]
}

model Role {
  id              String           @id
  name            String           @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  userRoles       UserRole[]
  rolePermissions RolePermission[]
}

model Permission {
  id              String           @id
  code            String           @unique
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
}

model RolePermission {
  roleId        String
  permissionId  String
  createdAt     DateTime   @default(now())
  role          Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model UserRole {
  userId     String
  roleId     String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model AuditLog {
  id            String   @id @default(uuid())
  eventType     String
  actorUserId   String?
  entityType    String?
  entityId      String?
  correlationId String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([eventType, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId, createdAt])
}

// Uniqueness across (priority, categoryId) is enforced via PARTIAL UNIQUE INDEXES
// created in migration `20260512150000_sla_config_partial_unique`. We can't use
// `@@unique([priority, categoryId])` here because Postgres treats NULL as
// distinct in unique indexes by default, which would allow two generic configs
// (categoryId IS NULL) with the same priority — see PROJ_LEARNING_NOTES §28.
model SlaConfig {
  id                   String         @id @default(uuid())
  name                 String
  priority             Priority
  categoryId           String?
  targetHours          Int
  warningThresholdPct  Int            @default(80)
  escalationRoleId     String?
  isActive             Boolean        @default(true)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  trackers             ComplaintSla[]

  @@index([priority, isActive])
}

model ComplaintSla {
  id            String    @id @default(uuid())
  complaintId   String    @unique
  slaConfigId   String
  startedAt     DateTime  @default(now())
  targetAt      DateTime
  warningAt     DateTime
  warnedAt      DateTime?
  breachedAt    DateTime?
  completedAt   DateTime?
  status        SlaStatus @default(ACTIVE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  complaint     Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  slaConfig     SlaConfig @relation(fields: [slaConfigId], references: [id])

  @@index([status])
  @@index([targetAt])
}
