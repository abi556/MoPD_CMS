generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ComplaintStatus {
  SUBMITTED
  TRIAGE
  ASSIGNED
  IN_INVESTIGATION
  DRAFT_RESPONSE
  QA_LEGAL_REVIEW
  RESPONSE_ISSUED
  AWAITING_FEEDBACK
  APPEAL
  CLOSED
}

enum ComplaintChannel {
  WEB
  ASSISTED
  EMAIL
  SMS
  USSD
}

enum ComplaintLocale {
  en
  am
}

model Complaint {
  id              String          @id @default(cuid())
  sequenceNo      Int             @unique @default(autoincrement())
  referenceNo     String          @unique
  status          ComplaintStatus @default(SUBMITTED)
  channel         ComplaintChannel
  subject         String
  description     String
  submittedAt     DateTime        @default(now())
  locale          ComplaintLocale
  consentGiven    Boolean
  complainantName String?
  complainantEmail String?
  complainantPhone String?
  assignedToUserId String?
  assignedByUserId String?
  assignedAt      DateTime?
  assignmentReason String?
  lastTransitionByUserId String?
  lastTransitionAt DateTime?
  lastTransitionReason String?
  history         ComplaintHistory[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([referenceNo])
  @@index([submittedAt])
}

model ComplaintHistory {
  id            String          @id @default(cuid())
  complaintId   String
  action        String
  fromStatus    ComplaintStatus?
  toStatus      ComplaintStatus
  actorUserId   String
  reason        String?
  createdAt     DateTime        @default(now())
  complaint     Complaint       @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId, createdAt])
}

model User {
  id           String     @id
  email        String     @unique
  passwordHash String
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  userRoles    UserRole[]
}

model Role {
  id              String           @id
  name            String           @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  userRoles       UserRole[]
  rolePermissions RolePermission[]
}

model Permission {
  id              String           @id
  code            String           @unique
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
}

model RolePermission {
  roleId        String
  permissionId  String
  createdAt     DateTime   @default(now())
  role          Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model UserRole {
  userId     String
  roleId     String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}
