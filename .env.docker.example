# Docker compose infrastructure variables (copy to .env.docker)

# App ports
API_PORT=REPLACE_ME
WEB_PORT=REPLACE_ME

# API/web runtime wiring
NEXT_PUBLIC_API_URL=REPLACE_ME
MINIO_ENDPOINT=REPLACE_ME

# Postgres
POSTGRES_DB=REPLACE_ME
POSTGRES_USER=REPLACE_ME
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_HOST_PORT=REPLACE_ME

# Redis
REDIS_PORT=REPLACE_ME

# MinIO
MINIO_ROOT_USER=REPLACE_ME
MINIO_ROOT_PASSWORD=replace-with-strong-password
MINIO_PORT=REPLACE_ME
MINIO_CONSOLE_PORT=REPLACE_ME
