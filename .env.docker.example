# Docker Compose infrastructure (copy to .env.docker at repo root)
# Usage from repo root:
#   docker compose -f infra/docker/docker-compose.yml --env-file .env.docker up -d

# App ports (profile "app" only)
API_PORT=3001
WEB_PORT=3000

# API/web runtime wiring
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
APP_PUBLIC_URL=http://localhost:3000
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@localhost

# Postgres
POSTGRES_DB=mopd_cms
POSTGRES_USER=mopd_cms
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_HOST_PORT=5433

# Redis
REDIS_PORT=6379

# MinIO (documents FR-09) — console http://localhost:9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace-with-strong-password
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
MINIO_BUCKET_QUARANTINE=mopd-quarantine
MINIO_BUCKET_LIVE=mopd-live
MINIO_PRESIGN_TTL_SEC=900

# ClamAV (documents FR-09) — first start can take 2+ minutes (virus defs)
CLAMAV_PORT=3310

# Document pipeline (API container when using --profile app)
DOCUMENT_STORAGE_DRIVER=minio
DOCUMENT_MAX_BYTES=26214400
VIRUS_SCANNER=clamav

# Mailpit (local dev only — not for production)
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025
